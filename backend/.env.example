# ─── Required (backend will not start without these) ─────────────────────────
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
GROQ_API_KEY=

# ─── Database (required for login, farms, history) ────────────────────────────
# Neon / local Postgres — keep sslmode=require for hosted DBs
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ─── Optional ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-local-dev-secret

# Extra CORS origins (comma-separated). localhost:5173 is already allowed in code.
# CORS_ORIGINS=https://your-app.vercel.app
